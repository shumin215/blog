---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { url } from '@utils/url';

const posts = (
  await getCollection('posts', ({ data }) => !data.draft && data.tags.includes('personal'))
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Personal" description="일상과 생각을 기록하는 공간">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Personal</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">일상과 생각을 기록하는 공간</p>
  </div>

  {posts.length > 0 ? (
    <div class="flex flex-col divide-y divide-gray-100 dark:divide-gray-800">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  ) : (
    <div class="py-20 text-center">
      <p class="text-gray-400 dark:text-gray-500 text-sm">아직 포스트가 없어요.</p>
    </div>
  )}
</BaseLayout>
