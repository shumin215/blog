---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { url } from '@utils/url';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [
  { id: 'AI', label: 'AI', color: 'blue' },
  { id: 'Computer Architecture', label: 'Computer Architecture', color: 'purple' },
  { id: 'Programming', label: 'Programming', color: 'green' },
  { id: 'Digital Logic', label: 'Digital Logic', color: 'orange' },
  { id: 'NAS', label: 'NAS', color: 'cyan' },
  { id: 'Series', label: 'Series', color: 'rose' },
] as const;

const postsByCategory = Object.fromEntries(
  categories.map((cat) => [cat.id, allPosts.filter((p) => p.data.category === cat.id)])
);

const seriesSubcategories = Object.entries(
  postsByCategory.Series.reduce<Record<string, number>>((acc, post) => {
    const subcategory = post.data.subcategory ?? 'General';
    acc[subcategory] = (acc[subcategory] ?? 0) + 1;
    return acc;
  }, {})
).sort((a, b) => b[1] - a[1]);

const colorMap = {
  blue:   { badge: 'bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300',   dot: 'bg-blue-500' },
  purple: { badge: 'bg-purple-100 text-purple-700 dark:bg-purple-950 dark:text-purple-300', dot: 'bg-purple-500' },
  green:  { badge: 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300',  dot: 'bg-green-500' },
  orange: { badge: 'bg-orange-100 text-orange-700 dark:bg-orange-950 dark:text-orange-300', dot: 'bg-orange-500' },
  cyan:   { badge: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-950 dark:text-cyan-300',    dot: 'bg-cyan-500' },
  rose:   { badge: 'bg-rose-100 text-rose-700 dark:bg-rose-950 dark:text-rose-300',    dot: 'bg-rose-500' },
};
---

<BaseLayout title="Playground" description="기술 탐구 공간 — AI, 프로그래밍, 하드웨어, 시리즈 포스트 모음" fullWidth={true}>
  <div class="flex">

    <!-- Left Sidebar: flush to the left edge -->
    <aside class="hidden lg:flex flex-col w-56 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto border-r border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-950 px-4 py-8">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-4 px-2">
        Categories
      </p>
      <nav>
        <ul class="space-y-0.5">
          <li>
            <button
              data-category="all"
              class="category-btn w-full text-left text-sm px-3 py-2 rounded-md transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-between gap-2"
            >
              <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-gray-400 shrink-0"></span>
                All
              </span>
              <span class="text-xs text-gray-400">{allPosts.length}</span>
            </button>
          </li>
          {categories.map((cat) => {
            const c = colorMap[cat.color];
            return (
              <li>
                <button
                  data-category={cat.id}
                  data-color={cat.color}
                  class="category-btn w-full text-left text-sm px-3 py-2 rounded-md transition-colors text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-between gap-2"
                >
                  <span class="flex items-center gap-2">
                    <span class={`w-2 h-2 rounded-full ${c.dot} shrink-0`}></span>
                    {cat.label}
                  </span>
                  <span class="text-xs text-gray-400">{postsByCategory[cat.id].length}</span>
                </button>
                {cat.id === 'Series' && seriesSubcategories.length > 0 && (
                  <ul class="mt-1 ml-4 space-y-0.5 border-l border-gray-100 dark:border-gray-800 pl-3">
                    {seriesSubcategories.map(([subcategory, count]) => (
                      <li>
                        <button
                          data-category="Series"
                          data-subcategory={subcategory}
                          class="category-btn w-full text-left text-xs px-3 py-1.5 rounded-md transition-colors text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 flex items-center justify-between gap-2"
                        >
                          <span>{subcategory}</span>
                          <span class="text-xs text-gray-400">{count}</span>
                        </button>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })}
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 min-w-0 max-w-5xl px-6 sm:px-10 py-10">
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Playground</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">기술 탐구 공간</p>
      </div>

      <!-- Mobile category scroll -->
      <div class="lg:hidden flex gap-2 overflow-x-auto pb-3 mb-6">
        <button data-category="all" class="category-btn shrink-0 text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 whitespace-nowrap">
          All
        </button>
        {categories.map((cat) => (
          <button
            data-category={cat.id}
            data-color={cat.color}
            class="category-btn shrink-0 text-xs font-medium px-3 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 whitespace-nowrap"
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Post grid -->
      <div id="post-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
        {allPosts.map((post) => {
          const cat = categories.find((c) => c.id === post.data.category);
          const c = cat ? colorMap[cat.color] : null;
          return (
            <article
              data-category={post.data.category ?? ''}
              data-subcategory={post.data.subcategory ?? ''}
              class="post-card group flex flex-col rounded-xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-sm transition-all"
            >
              <div class="flex items-start justify-between gap-2 mb-3">
                {cat && c ? (
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${c.badge}`}>
                    {cat.label}
                  </span>
                ) : (
                  <span />
                )}
                <time class="text-xs text-gray-400 dark:text-gray-500 shrink-0">
                  {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <a href={url(`/posts/${post.id}`)} class="flex-1">
                <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors leading-snug mb-2">
                  {post.data.title}
                </h2>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
              </a>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-3">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="text-xs text-gray-400 dark:text-gray-500">#{tag}</span>
                  ))}
                </div>
              )}
            </article>
          );
        })}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-20 text-center">
        <p class="text-gray-400 dark:text-gray-500 text-sm">이 카테고리에 아직 포스트가 없어요.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const emptyState = document.getElementById('empty-state');

  function activate(category: string, subcategory = '') {
    buttons.forEach((btn) => {
      const isActive = btn.dataset.category === category && (btn.dataset.subcategory ?? '') === subcategory;
      btn.classList.toggle('font-semibold', isActive);
      btn.classList.toggle('text-gray-900', isActive);
      btn.classList.toggle('dark:text-gray-100', isActive);
      btn.classList.toggle('bg-gray-100', isActive);
      btn.classList.toggle('dark:bg-gray-800', isActive);
    });

    let visible = 0;
    cards.forEach((card) => {
      const match =
        category === 'all' ||
        (card.dataset.category === category && (!subcategory || card.dataset.subcategory === subcategory));
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    });

    emptyState?.classList.toggle('hidden', visible > 0);
  }

  const [initialCategory, initialSubcategory = ''] = decodeURIComponent(location.hash.replace('#', '')).split('/');
  activate(initialCategory || 'all', initialSubcategory);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'all';
      const subcategory = btn.dataset.subcategory ?? '';
      const hash = subcategory ? `${cat}/${subcategory}` : cat;
      history.replaceState(null, '', cat === 'all' ? location.pathname : `#${encodeURIComponent(hash)}`);
      activate(cat, subcategory);
    });
  });
</script>
