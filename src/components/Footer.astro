---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-950">
  <div class="w-full max-w-3xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-gray-500 dark:text-gray-400">
    <p>© {year} Shumin's World. All rights reserved.</p>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/shumin215"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
      >
        GitHub
      </a>
      <a href="/rss.xml" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
        RSS
      </a>
    </div>
  </div>
</footer>
