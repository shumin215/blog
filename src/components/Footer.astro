---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-white">
  <div class="w-full max-w-3xl mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-gray-500">
    <p>© {year} Shumin's World. All rights reserved.</p>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-indigo-600 transition-colors"
      >
        GitHub
      </a>
      <a href="/rss.xml" class="hover:text-indigo-600 transition-colors"> RSS </a>
    </div>
  </div>
</footer>
