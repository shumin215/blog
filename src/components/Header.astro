---
import { url } from '@utils/url';

const navLinks = [
  { href: url('/'), label: 'Home' },
  { href: url('/tags'), label: 'Tags' },
  { href: url('/search'), label: 'Search' },
  { href: url('/about'), label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 dark:bg-gray-950/90 backdrop-blur border-b border-gray-100 dark:border-gray-800">
  <nav class="w-full max-w-3xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href={url('/')} class="text-lg font-bold text-gray-900 dark:text-gray-100 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
      Shumin's World
    </a>

    <div class="flex items-center gap-1">
      <!-- Desktop Nav -->
      <ul class="hidden sm:flex items-center gap-1">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`text-sm font-medium px-3 py-1.5 rounded-md transition-colors hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-gray-800 ${
                  currentPath === href
                    ? 'text-indigo-600 dark:text-indigo-400'
                    : 'text-gray-600 dark:text-gray-400'
                }`}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Mobile Nav -->
      <ul class="sm:hidden flex items-center gap-1">
        {
          navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`text-sm font-medium px-2 py-1 rounded transition-colors hover:text-indigo-600 dark:hover:text-indigo-400 ${
                  currentPath === href
                    ? 'text-indigo-600 dark:text-indigo-400'
                    : 'text-gray-600 dark:text-gray-400'
                }`}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="ml-2 p-1.5 rounded-md text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden dark:block"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="block dark:hidden"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
