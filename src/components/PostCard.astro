---
import { url } from '@utils/url';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-gray-100 dark:border-gray-800 rounded-xl p-6 hover:border-indigo-200 dark:hover:border-indigo-800 hover:shadow-sm transition-all bg-white dark:bg-gray-900">
  <a href={url(`/posts/${slug}`)} class="block">
    <div class="flex items-center gap-2 mb-2">
      <time datetime={date.toISOString()} class="text-xs text-gray-400 dark:text-gray-500 font-medium">
        {formattedDate}
      </time>
    </div>

    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors mb-2 leading-snug">
      {title}
    </h2>

    <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {
        tags.map((tag) => (
          <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400">
            #{tag}
          </span>
        ))
      }
    </div>
  </a>
</article>
