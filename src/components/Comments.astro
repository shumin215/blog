---
// Giscus comments component
// Setup steps:
//   1. Enable GitHub Discussions on your repo (shumin215/blog)
//   2. Install giscus GitHub App: https://github.com/apps/giscus
//   3. Visit https://giscus.app and configure your repo to get the values below
//   4. Replace the placeholder attribute values with your actual config
---

<section class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-6">Comments</h2>
  <div class="giscus-wrapper">
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo="shumin215/blog"
      data-repo-id="R_kgDORnBfEg"
      data-category="Announcements"
      data-category-id="DIC_kwDORnBfEs4C4bTk"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="light"
      data-lang="ko"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>

<script>
  // Sync giscus theme with dark mode toggle
  function updateGiscusTheme() {
    const isDark = document.documentElement.classList.contains('dark');
    const theme = isDark ? 'dark' : 'light';
    const iframe = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
    if (iframe) {
      iframe.contentWindow?.postMessage(
        { giscus: { setConfig: { theme } } },
        'https://giscus.app'
      );
    }
  }

  // Watch for dark mode class changes on <html>
  const observer = new MutationObserver(updateGiscusTheme);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>
