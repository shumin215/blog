---
interface Props {
  type?: 'info' | 'warn' | 'danger' | 'tip';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: {
    wrapper: 'bg-blue-50 border-blue-300 text-blue-900',
    icon: 'ℹ️',
    label: 'Info',
  },
  tip: {
    wrapper: 'bg-green-50 border-green-300 text-green-900',
    icon: '💡',
    label: 'Tip',
  },
  warn: {
    wrapper: 'bg-amber-50 border-amber-300 text-amber-900',
    icon: '⚠️',
    label: 'Warning',
  },
  danger: {
    wrapper: 'bg-red-50 border-red-300 text-red-900',
    icon: '🚨',
    label: 'Danger',
  },
};

const { wrapper, icon, label } = styles[type];
---

<div class={`not-prose my-6 flex gap-3 rounded-lg border-l-4 px-4 py-3 ${wrapper}`}>
  <span class="mt-0.5 shrink-0 text-base leading-6" role="img" aria-label={label}>{icon}</span>
  <div class="text-sm leading-relaxed [&>p]:m-0 [&>p+p]:mt-2">
    <slot />
  </div>
</div>
